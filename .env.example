# config/.env (Prod/Docker) bzw. ./.env (lokale Dev – Legacy-Fallback)
# Kopiere diese Datei nach config/.env und fülle die Werte aus.
LOXONE_USER="name-des-benutzers-in-der-loxone"
LOXONE_PASS="Passwort-des-benutzers-in-der-loxone"
LOXONE_IP=192.168.178.1

# Zentrale Haus-Config (Dev: UNC-Pfad zur NAS; Prod/Docker: weglassen → config/config.json)
# ENERGY_OPTIMIZER_CONFIG_PATH=\\DS-KO-DO-2\docker\energy_optimizer\config\config.json

# Laufzeitdaten (Dev: UNC-Pfad zur NAS; Prod/Docker: weglassen → runtime/)
# ENERGY_OPTIMIZER_RUNTIME_DIR=\\DS-KO-DO-2\docker\energy_optimizer\runtime

# Maschinenspezifische Einstellungen (Standard: runtime/local_settings.json)
# ENERGY_OPTIMIZER_LOCAL_SETTINGS_PATH=runtime/local_settings.json
