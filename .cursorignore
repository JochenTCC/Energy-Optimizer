# Cursor-Index: sensible und lokal-produktive Dateien ausschließen.
# Syntax wie .gitignore. Beispiel-/Schema-Dateien bleiben indexierbar.

# --- Zugangsdaten & Umgebung ---
.env
.env.*
!.env.example

# SSH-/TLS-Schlüssel (z. B. remote_backtesting.json → identity_file)
*.pem
*.key
id_rsa
id_ed25519

# --- Produktiv-Konfiguration (Loxone-IO, Standort, Pfade, Verbraucher) ---
config/config.json
config.json
config/backtesting_scenarios.json
backtesting_scenarios.json
config/remote_backtesting.json
remote_backtesting.json
runtime_settings.json

# --- Maschinenspezifische Runtime ---
runtime/*
!runtime/.gitkeep
!runtime/local_settings.example.json
runtime-prod/

# --- Laufzeit-Zustand & Optimierer-Output ---
flexible_consumers_state.json
pv_counter_state.json
cons_data_hourly.meta.json
cons_data_pending.json
optimizer_run_state.json
live_optimization_debug.json
backtesting_log.json
backtesting_cbc_events.jsonl
backtesting_logs/

# --- Verbrauchs-/Historiendaten & Logs ---
*.csv
!tests/fixtures/**/*.csv
Historical-Data/
data/cache/
*.log
energy_optimizer.log
system_history_log.csv
chart_debug/

# --- Produktiv-Dumps (lokal; Archiv unter tests/fixtures/prod_dumps/ bleibt für Regression) ---
# Enthält u. a. cons_data_hourly.csv und energy_optimizer.log aus NAS/runtime.zip
tests/fixtures/prod_dumps/**/live_optimization_debug.json
