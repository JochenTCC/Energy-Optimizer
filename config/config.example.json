{
    "$schema": "./config.schema.json",
    "market_prices": {
        "missing_price_strategy": "forecast",
        "forecast_model_path": "data/cache/price_model_coefficients.json"
    },
    "eauto_milp": {
        "live_modus_a_min_remaining_kwh": 2.8,
        "tie_break_on_epsilon": 0.001,
        "tie_break_time_epsilon": 0.0001
    },
    "ui": {
        "fragment_refresh_charts_sec": 60,
        "fragment_refresh_status_sec": 10,
        "main_sync_poll_sec": 15,
        "chart_debug_capture_enabled": false,
        "chart_debug_capture_dir": "chart_debug",
        "streamlit_port": 8501,
        "price_forecast_page_enabled": false
    },
    "system": {
        "global_timeout": 10,
        "loop_timeout": 900,
        "event_trigger_enabled": true,
        "event_poll_interval_sec": 60,
        "loxone_silent_mode": true,
        "event_triggers": [
            {
                "id": "eauto_plugged_in",
                "loxone_name": "Ernie_EAuto_Da",
                "signal_type": "binary",
                "on_change": "any",
                "label": "E-Auto angeschlossen"
            },
            {
                "id": "eauto_charge_immediate",
                "loxone_name": "E-Auto_SOFORT_LADEN",
                "signal_type": "binary",
                "on_change": "any",
                "label": "E-Auto wird sofort geladen"
            },
            {
                "id": "eauto_ready_by",
                "loxone_name": "Ernie_EAuto_FertigUm",
                "signal_type": "text",
                "on_change": "any",
                "label": "E-Auto Fertig-Uhrzeit"
            },
            {
                "id": "eauto_rest_soc",
                "loxone_name": "Rest-SOC",
                "signal_type": "analog",
                "on_change": "any",
                "label": "E-Auto Rest-SOC"
            }
        ]
    },
    "loxone_blocks": {
        "soc_name": "B004-Battery_SOC",
        "pv_counter_name": "48 - Accumulated energy yield",
        "log_filename": "Verbrauch.csv",
        "pv_tuning_log_file": "runtime/pv_accuracy_log.csv",
        "pv_power_name": "Ernie-Merker-PV_Act",
        "battery_power_name": "Ernie-Merker-LeistungBat_Act",
        "grid_power_name": "Ernie-Merker-LeistungNetz_Act",
        "target_soc_name": "Ernie_Ziel_SoC",
        "target_charge_power_name": "Ernie_Ziel_LadeLeistung",
        "target_discharge_power_name": "Ernie_Ziel_Entladeleistung",
        "control_cmd_name": "Ernie_Steuerbefehl"
    },
    "runtime_settings": {
        "battery_id": "default_5kwh",
        "pv_system_id": "roof_south",
        "import_tariff_id": "awattar_at",
        "export_tariff_id": "fixed_37ct"
    },
    "batteries": [
        {
            "id": "default_5kwh",
            "label": "5 kWh Speicher",
            "battery_capacity_kwh": 5.0,
            "battery_max_power_kw": 2.5,
            "battery_efficiency": 0.97,
            "battery_min_soc": 10.0,
            "battery_max_soc": 100.0,
            "threshold_power": 0.05,
            "battery_wear": {
                "enabled": true,
                "replacement_cost_euro": 1500,
                "expected_cycles": 6000,
                "cycle_cost_fraction": 0.5
            }
        },
        {
            "id": "upgrade_10kwh",
            "label": "10 kWh Speicher",
            "battery_capacity_kwh": 10.0,
            "battery_max_power_kw": 5.0,
            "battery_efficiency": 0.97,
            "battery_min_soc": 10.0,
            "battery_max_soc": 100.0,
            "threshold_power": 0.02,
            "battery_wear": {
                "enabled": true,
                "replacement_cost_euro": 3000,
                "expected_cycles": 6000,
                "cycle_cost_fraction": 0.5
            }
        }
    ],
    "pv_systems": [
        {
            "id": "roof_south",
            "label": "Dach Süd 10 kWp",
            "kwp": 10,
            "pv_tilt": 25,
            "pv_azimuth": 0
        }
    ],
    "planning_horizon": {
        "mode": "sunset_window"
    },
    "flexible_consumers": [
        {
            "id": "swimspa",
            "name": "SwimSpa",
            "chart_color_index": 0,
            "nominal_power_kw": 2.8,
            "daily_target_kwh": 5.0,
            "daily_target_source": "thermal",
            "min_on_quarterhours": 8,
            "path_log": "pfad/zum/swimspa-log.csv",
            "signal_type": "power",
            "optimizer_enabled": true,
            "loxone_outputs": {
                "enable_name": "Ernie_SwimSpa_Freigabe"
            },
            "loxone_inputs": {
                "power_name": "Ernie_Swim-Spa-P_act",
                "subtract_consumer_ids": ["swimspa_filter"]
            },
            "thermal_control": {
                "enabled": true,
                "mode": "active",
                "setpoint_c": 36.5,
                "tolerance_c": 1.0,
                "water_volume_liters": 6000,
                "heat_loss_kw_per_k": 0.1,
                "heating_efficiency": 0.95,
                "heating_power_threshold_kw": 2.0,
                "actual_temp_step_c": 0.5,
                "history_logs": {
                    "actual_temp_csv": "./Historical-Data/Miniserver-Gen2_SwimSpa_IstTemperatur_20230701-20260702.csv",
                    "ambient_temp_csv": "./Historical-Data/Miniserver-Gen2_SwimSpa_AussenTemperatur_20230701-20260702.csv",
                    "power_csv": "./Historical-Data/Miniserver-Gen2_SwimSpa_Leistung_20230701-20260702.csv"
                },
                "loxone": {
                    "actual_temp_name": "homie_bwa_spa_currenttemperature",
                    "setpoint_temp_name": "SwimSpa_Temp_Soll",
                    "ambient_temp_name": "Außentemperatur",
                    "tolerance_c_name": "SwimSpa_Max_Temp_Delta"
                }
            }
        },
        {
            "id": "swimspa_filter",
            "name": "SwimSpa Filter",
            "chart_color_index": 1,
            "nominal_power_kw": 0.18,
            "daily_target_kwh": 0.36,
            "daily_target_source": "loxone_remaining_hours",
            "loxone_target_hours_name": "Ernie_Swimspa_Filter_Sollstunden",
            "signal_type": "binary",
            "min_on_quarterhours": 2,
            "optimizer_enabled": true,
            "loxone_outputs": {
                "enable_name": "Ernie_Swimspa_Filter_Freigabe"
            },
            "loxone_inputs": {
                "power_name": "homie_bwa_spa_filter2",
                "alternate_binary_power_name": "homie_bwa_spa_filter1",
                "signal_type": "binary"
            },
            "filter_schedule": {
                "enabled": true,
                "loxone": {
                    "native_start_hour_name": "homie_bwa_spa_filter1hour",
                    "native_duration_hours_name": "homie_bwa_spa_filter1durationhours"
                },
                "config_fallback": {
                    "native_start_hour": 10,
                    "native_duration_hours": 4.0
                }
            }
        },
        {
            "id": "eauto",
            "name": "E-Auto",
            "chart_color_index": 2,
            "nominal_power_kw": 3.5,
            "min_power_kw": 1.4,
            "daily_target_source": "config",
            "min_on_quarterhours": 4,
            "path_log": "pfad/zum/eauto-log.csv",
            "signal_type": "power",
            "optimizer_enabled": true,
            "loxone_outputs": {
                "power_setpoint_name": "Ernie_EAuto_Ziel_kW",
                "pv_follow_name": "Ernie_EAuto_pv_follow"
            },
            "loxone_inputs": {
                "power_name": "Ernie_EAuto_P_act"
            },
            "charging_schedule": {
                "enabled": true,
                "forecast_when_absent": true,
                "target_soc_percent": 100.0,
                "charging_efficiency": 0.95,
                "weekday": {
                    "car_available_from_hour": 18,
                    "ready_by_hour": 7,
                    "daily_rest_soc": 40.0
                },
                "weekend": {
                    "car_available_from_hour": 20,
                    "ready_by_hour": 9,
                    "daily_rest_soc": 30.0
                },
                "loxone": {
                    "plugged_in_name": "Ernie_EAuto_Da",
                    "ready_by_time_name": "Ernie_EAuto_FertigUm",
                    "soc_at_plug_in_name": "Rest-SOC",
                    "charge_immediate_name": "E-Auto_SOFORT_LADEN",
                    "charge_immediate_remaining_name": "Ernie_Restzeit_Sofortladen",
                    "battery_capacity_kwh_name": "Batteriekapazität_E-Auto",
                    "nominal_power_kw_name": "Ladestrom Max EAuto"
                }
            }
        },
        {
            "id": "waermepumpe",
            "name": "Wärmepumpe",
            "chart_color_index": 7,
            "nominal_power_kw": 1.6,
            "daily_target_kwh": 4.0,
            "daily_target_source": "historical",
            "min_on_quarterhours": 2,
            "path_log": "./Historical-Data/Miniserver-Gen2_AnforderungWärmepumpe_20190101-20260610.csv",
            "signal_type": "power",
            "log_signal_type": "binary",
            "optimizer_enabled": true,
            "loxone_outputs": {
                "enable_name": "Ernie_WP_Freigabe"
            },
            "loxone_inputs": {
                "power_name": "Ernie_WP_P_act"
            }
        }

    ],
    "appliances": [
        {
            "id": "waschmaschine",
            "name": "Waschmaschine",
            "power_source": "loxone",
            "loxone_power_name": "Leistung Waschmaschine",
            "default_power_kw": 2.0,
            "default_runtime_h": 2.0
        },
        {
            "id": "trockner",
            "name": "Trockner",
            "power_source": "loxone",
            "loxone_power_name": "Leistung Trockner",
            "default_power_kw": 2.5,
            "default_runtime_h": 1.5
        },
        {
            "id": "geschirrspueler",
            "name": "Geschirrspüler",
            "power_source": "manual",
            "default_power_kw": 1.2,
            "default_runtime_h": 2.5
        }
    ],
    "appliance_recommendation": {
        "abs_margin_cent": 0.05,
        "pct_stars_4": 10.0,
        "pct_stars_1": 30.0
    },
    "file_paths_battery_simulation": {
        "path_cons_data": "runtime/cons_data_hourly.csv",
        "cons_data_retention_months": 24,
        "cons_data_write_mode": "hourly",
        "price_source": "api",
        "price_provider": "awattar",
        "price_range": "last_12_months"
    }
}
