{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://energy-optimizer.local/house_profiles.schema.json",
    "title": "Energy Optimizer Hausprofile",
    "type": "object",
    "properties": {
        "profiles": {
            "type": "array",
            "items": { "$ref": "#/definitions/profile" }
        }
    },
    "definitions": {
        "schedule": {
            "type": "object",
            "properties": {
                "runs_per_week": { "type": "integer", "minimum": 0 },
                "duration_h": { "type": "number", "minimum": 0 },
                "start_hour": { "type": "integer", "minimum": 0, "maximum": 23 },
                "start_shift_h": { "type": "number", "minimum": 0, "maximum": 12 }
            }
        },
        "day_schedule": {
            "type": "object",
            "properties": {
                "car_available_from_hour": { "type": "integer", "minimum": 0, "maximum": 23 },
                "ready_by_hour": { "type": "integer", "minimum": 0, "maximum": 23 },
                "daily_rest_soc": { "type": "number", "minimum": 0, "maximum": 100 }
            }
        },
        "ev_charging_schedule": {
            "type": "object",
            "properties": {
                "target_soc_percent": { "type": "number", "minimum": 0, "maximum": 100 },
                "charging_efficiency": { "type": "number", "exclusiveMinimum": 0, "maximum": 1 },
                "forecast_when_absent": { "type": "boolean" },
                "weekday": { "$ref": "#/definitions/day_schedule" },
                "weekend": { "$ref": "#/definitions/day_schedule" }
            }
        },
        "consumer": {
            "type": "object",
            "required": ["id"],
            "properties": {
                "id": { "type": "string" },
                "label": { "type": "string" },
                "type": { "enum": ["generic", "thermal_annual", "ev"] },
                "nominal_power_kw": { "type": "number" },
                "annual_kwh": { "type": "number" },
                "profile_csv": { "type": "string" },
                "schedule": { "$ref": "#/definitions/schedule" },
                "min_power_kw": { "type": "number", "minimum": 0 },
                "min_on_quarterhours": { "type": "integer", "minimum": 0 },
                "battery_capacity_kwh": { "type": "number", "exclusiveMinimum": 0 },
                "charging_schedule": { "$ref": "#/definitions/ev_charging_schedule" },
                "living_area_m2": { "type": "number" },
                "building_class": { "type": "integer", "minimum": 1, "maximum": 4 },
                "hwb_kwh_m2": {
                    "type": "number",
                    "exclusiveMinimum": 0,
                    "description": "Optional: genauer Heizwärmebedarf HWB in kWh/m²a (überschreibt Gebäudeklasse)."
                },
                "heat_pump_type": { "enum": ["luft", "erde"] },
                "persons": { "type": "integer", "minimum": 0 },
                "target_temp_c": { "type": "number" },
                "heating_limit_c": { "type": "number" }
            }
        },
        "profile": {
            "type": "object",
            "required": ["id", "annual_kwh"],
            "properties": {
                "id": { "type": "string" },
                "label": { "type": "string" },
                "annual_kwh": { "type": "number", "minimum": 0 },
                "total_profile_csv": { "type": "string" },
                "consumers": {
                    "type": "array",
                    "items": { "$ref": "#/definitions/consumer" }
                }
            }
        }
    }
}
