{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://energy-optimizer.local/backtesting_scenarios.schema.json",
  "title": "Energy Optimizer Backtesting-Szenarien",
  "description": "Alternative Parameter-Sets nur für Simulation und Backtesting. runtime_settings bleiben in config.json.",
  "type": "object",
  "required": ["scenarios"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Verweis auf diese Schema-Datei für Editor-Hilfen."
    },
    "cbc_gap_rel": {
      "type": "number",
      "exclusiveMinimum": 0,
      "exclusiveMaximum": 1,
      "description": "Relativer CBC-MIP-Gap für Backtesting (z. B. 0.10 = 10 %). Fehlt der Wert, gilt 10 %."
    },
    "cbc_strict_time_limit_sec": {
      "type": "number",
      "minimum": 0,
      "description": "Sekunden für Strict-CBC vor gapRel-Fallback (0 = Strict überspringen). Standard: 3."
    },
    "fixed_monthly_feed_in_rates": {
      "type": "array",
      "description": "Monatliche aWATTar-SUNNY-Fixtarife (Cent/kWh netto) für feed_in_mode=fixed im Backtesting.",
      "items": {
        "type": "object",
        "required": ["year", "month", "tariff_cent_kwh"],
        "properties": {
          "year": {
            "type": "integer",
            "minimum": 2000,
            "description": "Kalenderjahr des Tarifs."
          },
          "month": {
            "type": "integer",
            "minimum": 1,
            "maximum": 12,
            "description": "Kalendermonat (1–12)."
          },
          "tariff_cent_kwh": {
            "type": "number",
            "exclusiveMinimum": 0,
            "description": "Einspeisevergütung in Cent/kWh (netto) für diesen Monat."
          }
        }
      }
    },
    "scenarios": {
      "type": "array",
      "description": "Zusätzliche Szenarien neben runtime_settings (Baseline) aus config.json.",
      "items": {
        "$ref": "#/definitions/scenario"
      }
    }
  },
  "definitions": {
    "scenario": {
      "type": "object",
      "description": "Benanntes Szenario für Simulation/Backtesting.",
      "required": ["id", "label", "settings"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Eindeutige Szenario-Kennung (z. B. battery_10kwh). Nicht 'runtime_settings' verwenden."
        },
        "label": {
          "type": "string",
          "description": "Anzeigename in der UI."
        },
        "settings": {
          "type": "object",
          "description": "Parameter-Override (gleiche Felder wie runtime_settings in config.json).",
          "properties": {
            "k_push_cent": { "type": "number" },
            "feed_in_mode": {
              "type": "string",
              "enum": ["fixed", "dynamic_epex"]
            },
            "pv_tilt": { "type": "number" },
            "pv_azimuth": { "type": "number" },
            "pv_kwp": { "type": "number" },
            "battery_max_power_kw": { "type": "number" },
            "battery_efficiency": { "type": "number" },
            "battery_capacity_kwh": { "type": "number" },
            "battery_min_soc": { "type": "number" },
            "battery_max_soc": { "type": "number" },
            "threshold_power": { "type": "number" },
            "latitude": { "type": "number" },
            "longitude": { "type": "number" }
          }
        }
      }
    }
  }
}
