{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "main.py",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Streamlit app.py",
      "type": "python",
      "request": "launch",
      "module": "scripts.run_streamlit",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Streamlit app.py (nach 15s)",
      "type": "python",
      "request": "launch",
      "preLaunchTask": "wait: 15s vor Streamlit",
      "module": "scripts.run_streamlit",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Streamlit app.py (NAS Produktiv-Log)",
      "type": "python",
      "request": "launch",
      "module": "scripts.run_streamlit",
      "cwd": "${workspaceFolder}",
      "env": {
        "ENERGY_OPTIMIZER_RUNTIME_DIR": "\\\\DS-KO-DO-2\\docker\\energy_optimizer\\runtime",
        "ENERGY_OPTIMIZER_CONFIG_PATH": "\\\\DS-KO-DO-2\\docker\\energy_optimizer\\config\\config.json"
      },
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Streamlit app.py (Deviation-Test)",
      "type": "python",
      "request": "launch",
      "preLaunchTask": "seed: deviation test log",
      "module": "scripts.run_streamlit",
      "cwd": "${workspaceFolder}",
      "env": {
        "ENERGY_OPTIMIZER_RUNTIME_DIR": "${workspaceFolder}/runtime"
      },
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "run_backtesting",
      "type": "python",
      "request": "launch",
      "module": "scripts.run_backtesting",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false
    }
  ],
  "compounds": [
    {
      "name": "main.py + Streamlit app.py",
      "configurations": [
        "main.py",
        "Streamlit app.py (nach 15s)"
      ],
      "stopAll": true
    }
  ]
}
