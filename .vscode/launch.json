{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "main.py",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Streamlit app.py",
      "type": "python",
      "request": "launch",
      "module": "streamlit",
      "args": [
        "run",
        "${workspaceFolder}/app.py",
        "--server.port",
        "8501"
      ],
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Streamlit app.py (nach 15s)",
      "type": "python",
      "request": "launch",
      "preLaunchTask": "wait: 15s vor Streamlit",
      "module": "streamlit",
      "args": [
        "run",
        "${workspaceFolder}/app.py",
        "--server.port",
        "8501"
      ],
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "run_backtesting",
      "type": "python",
      "request": "launch",
      "module": "scripts.run_backtesting",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false
    }
  ],
  "compounds": [
    {
      "name": "main.py + Streamlit app.py",
      "configurations": [
        "main.py",
        "Streamlit app.py (nach 15s)"
      ],
      "stopAll": true
    }
  ]
}
