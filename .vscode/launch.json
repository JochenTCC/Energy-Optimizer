{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "main.py",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Streamlit app.py (:8501 lokal)",
      "type": "python",
      "request": "launch",
      "module": "scripts.run_streamlit",
      "console": "integratedTerminal",
      "env": {
        "ENERGY_OPTIMIZER_UI_STREAMLIT_PORT": "8501"
      },
      "subProcess": false,
      "justMyCode": false
    },
    {
      "name": "Streamlit app.py (nach 15s, :8501)",
      "type": "python",
      "request": "launch",
      "preLaunchTask": "wait: 15s vor Streamlit",
      "module": "scripts.run_streamlit",
      "console": "integratedTerminal",
      "env": {
        "ENERGY_OPTIMIZER_UI_STREAMLIT_PORT": "8501"
      },
      "subProcess": false,
      "justMyCode": false
    },
    {
      "name": "Streamlit app.py (NAS :8503)",
      "type": "python",
      "request": "launch",
      "module": "scripts.run_streamlit",
      "cwd": "${workspaceFolder}",
      "env": {
        "ENERGY_OPTIMIZER_RUNTIME_DIR": "\\\\DS-KO-DO-2\\docker\\energy_optimizer\\runtime",
        "ENERGY_OPTIMIZER_CONFIG_PATH": "\\\\DS-KO-DO-2\\docker\\energy_optimizer\\config\\config.json",
        "ENERGY_OPTIMIZER_UI_STREAMLIT_PORT": "8503"
      },
      "subProcess": false,
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Streamlit app.py (LOKAL, Greenfield :8511)",
      "type": "python",
      "request": "launch",
      "module": "scripts.run_streamlit",
      "cwd": "${workspaceFolder}",
      "env": {
        "ENERGY_OPTIMIZER_CONFIG_PATH": "${workspaceFolder}/greenfield/config/config.json",
        "ENERGY_OPTIMIZER_RUNTIME_DIR": "${workspaceFolder}/greenfield/runtime",
        "ENERGY_OPTIMIZER_DOTENV_PATH": "${workspaceFolder}/greenfield/config/.env",
        "ENERGY_OPTIMIZER_HOUSE_PROFILES_PATH": "${workspaceFolder}/greenfield/config/house_profiles.json",
        "ENERGY_OPTIMIZER_TARIFFS_PATH": "${workspaceFolder}/greenfield/config/tariffs.json",
        "ENERGY_OPTIMIZER_BACKTESTING_SCENARIOS_PATH": "${workspaceFolder}/greenfield/config/backtesting_scenarios.json",
        "ENERGY_OPTIMIZER_VERIFY_LOXONE_ON_START": "0",
        "ENERGY_OPTIMIZER_UI_MODES": "sunset2sunset,backtesting",
        "ENERGY_OPTIMIZER_UI_STREAMLIT_PORT": "8511"
      },
      "subProcess": false,
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Streamlit app.py (Deviation-Test)",
      "type": "python",
      "request": "launch",
      "preLaunchTask": "seed: deviation test log",
      "module": "scripts.run_streamlit",
      "cwd": "${workspaceFolder}",
      "env": {
        "ENERGY_OPTIMIZER_RUNTIME_DIR": "${workspaceFolder}/runtime",
        "ENERGY_OPTIMIZER_UI_STREAMLIT_PORT": "8501"
      },
      "subProcess": false,
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "main.py (Greenfield)",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/main.py",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "env": {
        "ENERGY_OPTIMIZER_CONFIG_PATH": "${workspaceFolder}/greenfield/config/config.json",
        "ENERGY_OPTIMIZER_RUNTIME_DIR": "${workspaceFolder}/greenfield/runtime",
        "ENERGY_OPTIMIZER_DOTENV_PATH": "${workspaceFolder}/greenfield/config/.env",
        "ENERGY_OPTIMIZER_HOUSE_PROFILES_PATH": "${workspaceFolder}/greenfield/config/house_profiles.json",
        "ENERGY_OPTIMIZER_TARIFFS_PATH": "${workspaceFolder}/greenfield/config/tariffs.json",
        "ENERGY_OPTIMIZER_BACKTESTING_SCENARIOS_PATH": "${workspaceFolder}/greenfield/config/backtesting_scenarios.json",
        "ENERGY_OPTIMIZER_VERIFY_LOXONE_ON_START": "0"
      },
      "justMyCode": false
    },
    {
      "name": "Streamlit app.py (nach 15s, Greenfield :8511)",
      "type": "python",
      "request": "launch",
      "preLaunchTask": "wait: 15s vor Streamlit",
      "module": "scripts.run_streamlit",
      "cwd": "${workspaceFolder}",
      "env": {
        "ENERGY_OPTIMIZER_CONFIG_PATH": "${workspaceFolder}/greenfield/config/config.json",
        "ENERGY_OPTIMIZER_RUNTIME_DIR": "${workspaceFolder}/greenfield/runtime",
        "ENERGY_OPTIMIZER_DOTENV_PATH": "${workspaceFolder}/greenfield/config/.env",
        "ENERGY_OPTIMIZER_HOUSE_PROFILES_PATH": "${workspaceFolder}/greenfield/config/house_profiles.json",
        "ENERGY_OPTIMIZER_TARIFFS_PATH": "${workspaceFolder}/greenfield/config/tariffs.json",
        "ENERGY_OPTIMIZER_BACKTESTING_SCENARIOS_PATH": "${workspaceFolder}/greenfield/config/backtesting_scenarios.json",
        "ENERGY_OPTIMIZER_VERIFY_LOXONE_ON_START": "0",
        "ENERGY_OPTIMIZER_UI_MODES": "sunset2sunset,backtesting",
        "ENERGY_OPTIMIZER_UI_STREAMLIT_PORT": "8511"
      },
      "subProcess": false,
      "console": "integratedTerminal",
      "justMyCode": false
    }
  ],
  "compounds": [
    {
      "name": "main.py + Streamlit (:8501 lokal)",
      "configurations": [
        "main.py",
        "Streamlit app.py (nach 15s, :8501)"
      ],
      "stopAll": true
    },
    {
      "name": "main.py + Streamlit (Greenfield :8511)",
      "configurations": [
        "main.py (Greenfield)",
        "Streamlit app.py (nach 15s, Greenfield :8511)"
      ],
      "stopAll": true
    }
  ]
}
