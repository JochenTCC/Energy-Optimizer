{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "caddy: run",
      "type": "shell",
      "command": "& 'C:\\Tools\\Caddy\\caddy.exe' run --config '${workspaceFolder}\\deploy\\caddy\\Caddyfile'",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "problemMatcher": {
        "owner": "caddy",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "serving initial configuration"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "group": "caddy"
      }
    },
    {
      "label": "caddy: stop",
      "type": "shell",
      "command": "Stop-Process -Name caddy -Force -ErrorAction SilentlyContinue",
      "presentation": {
        "reveal": "silent",
        "panel": "shared"
      }
    },
    {
      "label": "seed: deviation test log",
      "type": "shell",
      "command": "& '${workspaceFolder}\\.venv\\Scripts\\python.exe' -m scripts.seed_deviation_test_log --force",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "showReuseMessage": false
      }
    }
  ]
}
