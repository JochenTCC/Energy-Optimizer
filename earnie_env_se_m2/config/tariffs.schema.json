{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://earnie.local/tariffs.schema.json",
  "title": "Earnie Stromtarife",
  "type": "object",
  "properties": {
    "catalog_as_of": {
      "type": "string",
      "description": "Stand/Datum der Tarifliste (z. B. 2026 oder 2026-03-01)."
    },
    "import_tariffs": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/import_tariff"
      }
    },
    "export_tariffs": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/export_tariff"
      }
    },
    "oemag_monthly_feed_in_rates": {
      "$ref": "#/definitions/monthly_rates",
      "description": "OeMAG Gesetzlicher Marktpreis (Wartungs-Referenzkurve fuer Monats-Einspeisetarife): mindestens 12 Monate Cent/kWh netto; laenger erlaubt fuer SE-Zeitraeume.",
      "minItems": 12
    },
    "monthly_float_reference_cent_kwh": {
      "type": "number",
      "exclusiveMinimum": 0,
      "description": "Historischer OeMAG-Nenner fuer Katalog-Seeds (z. B. 7.15). Runtime nutzt owned monthly_rates."
    },
    "earnie_data_model": {
      "type": "integer",
      "const": 3,
      "description": "Earnie data-model version for config pack import/export."
    },
    "econtrol_referenzmarktwert_pv_monthly": {
      "$ref": "#/definitions/monthly_rates",
      "description": "E-Control Referenzmarktwert PV gemaess §13 EAG (Wartungs-Referenzkurve): mindestens 12 Monate Cent/kWh; z. B. fuer VKW PV-Einspeisetarif Flex.",
      "minItems": 12
    }
  },
  "definitions": {
    "dach_common": {
      "type": "object",
      "properties": {
        "land": {
          "type": "string",
          "enum": [
            "AT",
            "DE",
            "CH"
          ]
        },
        "currency": {
          "type": "string",
          "enum": [
            "EUR",
            "CHF"
          ]
        },
        "settlement_fee_cent_kwh": {
          "type": "number",
          "minimum": 0
        },
        "markup_percent": {
          "type": "number"
        },
        "prices_include_vat": {
          "type": "boolean"
        },
        "vat_percent": {
          "type": "number",
          "minimum": 0
        },
        "netzentgelt_cent_kwh": {
          "type": "number",
          "minimum": 0
        },
        "monthly_fee_eur": {
          "type": "number",
          "minimum": 0,
          "description": "Approximate monthly standing charge in EUR/month (net if prices_include_vat is false, else gross). Used in Scenario Explorer totals only."
        },
        "supplier_id": {
          "type": "string",
          "minLength": 1,
          "description": "Stable Stromlieferant slug for SE monthly-fee dedupe (same supplier → fee once)."
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "monthly_rates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "year",
          "month",
          "tariff_cent_kwh"
        ],
        "properties": {
          "year": {
            "type": "integer"
          },
          "month": {
            "type": "integer",
            "minimum": 1,
            "maximum": 12
          },
          "tariff_cent_kwh": {
            "type": "number",
            "exclusiveMinimum": 0
          }
        }
      }
    },
    "spot_export_pricing": {
      "type": "object",
      "description": "Optional percent haircut / fix offset on hourly EPEX export (e.g. aWATTar SUNNY SPOT).",
      "properties": {
        "feed_in_fee_factor": {
          "type": "number",
          "minimum": 0,
          "description": "Bearbeitungsgebühr auf |EPEX| (z. B. 0.19)."
        },
        "feed_in_fix_cent": {
          "type": "number",
          "description": "Fixer Cent/kWh-Offset auf die Einspeisevergütung (additiv)."
        }
      }
    },
    "import_tariff": {
      "allOf": [
        {
          "$ref": "#/definitions/dach_common"
        },
        {
          "type": "object",
          "required": [
            "id",
            "type",
            "supplier_id"
          ],
          "properties": {
            "id": {
              "type": "string"
            },
            "label": {
              "type": "string"
            },
            "type": {
              "enum": [
                "fixed_cent",
                "spot_hourly",
                "ex_post_spot",
                "monthly_market",
                "monthly_table"
              ]
            },
            "fix_cent_kwh": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "monthly_rates": {
              "$ref": "#/definitions/monthly_rates"
            }
          }
        }
      ]
    },
    "export_tariff": {
      "allOf": [
        {
          "$ref": "#/definitions/dach_common"
        },
        {
          "type": "object",
          "required": [
            "id",
            "type",
            "supplier_id"
          ],
          "properties": {
            "id": {
              "type": "string"
            },
            "label": {
              "type": "string"
            },
            "type": {
              "enum": [
                "fixed",
                "monthly_table",
                "spot_hourly",
                "ex_post_spot"
              ]
            },
            "k_push_cent": {
              "type": "number"
            },
            "monthly_rates": {
              "$ref": "#/definitions/monthly_rates"
            },
            "feed_in_fee_factor": {
              "type": "number",
              "minimum": 0
            },
            "feed_in_fix_cent": {
              "type": "number"
            }
          }
        }
      ]
    }
  }
}
