{
    "$schema": "./backtesting_scenarios.schema.json",
    "earnie_data_model": 3,
    "cbc_gap_rel": 0.1,
    "cbc_strict_time_limit_sec": 3,
    "scenarios": [
        {
            "id": "live",
            "label": "Live",
            "settings": {
                "battery_id": "default_5kwh",
                "pv_system_ids": [
                    "roof_south"
                ],
                "import_tariff_id": "awattar_at",
                "export_tariff_id": "fixed_37ct",
                "house_profile_id": "example_efh"
            }
        },
        {
            "id": "battery_5kwh_dynamic",
            "label": "5 kWh, dynamische Einspeise",
            "settings": {
                "k_push_cent": 3.7,
                "feed_in_mode": "dynamic_epex",
                "pv_tilt": 25,
                "pv_azimuth": 0,
                "pv_kwp": 10,
                "battery_max_power_kw": 2.5,
                "battery_efficiency": 0.97,
                "battery_capacity_kwh": 5.0,
                "battery_min_soc": 10.0,
                "battery_max_soc": 100.0,
                "threshold_power": 0.02
            }
        },
        {
            "id": "battery_10kwh_fixed",
            "label": "10 kWh, fixe Einspeise",
            "settings": {
                "k_push_cent": 3.7,
                "feed_in_mode": "fixed",
                "pv_tilt": 25,
                "pv_azimuth": 0,
                "pv_kwp": 10,
                "battery_max_power_kw": 5.0,
                "battery_efficiency": 0.97,
                "battery_capacity_kwh": 10.0,
                "battery_min_soc": 10.0,
                "battery_max_soc": 100.0,
                "threshold_power": 0.02
            }
        },
        {
            "id": "battery_10kwh_dynamic",
            "label": "10 kWh, dynamische Einspeise",
            "settings": {
                "k_push_cent": 3.7,
                "feed_in_mode": "dynamic_epex",
                "pv_tilt": 25,
                "pv_azimuth": 0,
                "pv_kwp": 10,
                "battery_max_power_kw": 5.0,
                "battery_efficiency": 0.97,
                "battery_capacity_kwh": 10.0,
                "battery_min_soc": 10.0,
                "battery_max_soc": 100.0,
                "threshold_power": 0.02
            }
        },
        {
            "id": "entity_refs_planning",
            "label": "10 kWh + monatliche Einspeise (Entitäten-Referenzen)",
            "settings": {
                "battery_id": "upgrade_10kwh",
                "pv_system_ids": [
                    "roof_south"
                ],
                "import_tariff_id": "awattar_at",
                "export_tariff_id": "monthly_sunny",
                "house_profile_id": "example_efh"
            }
        }
    ]
}
