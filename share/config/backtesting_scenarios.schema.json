{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://earnie.local/backtesting_scenarios.schema.json",
  "title": "Earnie Backtesting-Szenarien",
  "description": "Szenarien für Szenario-Explorer und Live-Betrieb (live_scenario_id in config.json).",
  "type": "object",
  "required": [
    "scenarios"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Verweis auf diese Schema-Datei für Editor-Hilfen."
    },
    "cbc_gap_rel": {
      "type": "number",
      "exclusiveMinimum": 0,
      "exclusiveMaximum": 1,
      "description": "Relativer CBC-MIP-Gap für Backtesting (z. B. 0.10 = 10 %). Fehlt der Wert, gilt 10 %."
    },
    "cbc_strict_time_limit_sec": {
      "type": "number",
      "minimum": 0,
      "description": "Sekunden für Strict-CBC vor gapRel-Fallback (0 = Strict überspringen). Standard: 3."
    },
    "scenarios": {
      "type": "array",
      "description": "Alle Szenarien inkl. Live-Baseline (Standard-ID: live, gewählt via live_scenario_id).",
      "items": {
        "$ref": "#/definitions/scenario"
      }
    },
    "earnie_data_model": {
      "type": "integer",
      "const": 2,
      "description": "Earnie data-model version for config pack import/export."
    }
  },
  "definitions": {
    "scenario": {
      "type": "object",
      "description": "Benanntes Szenario für Simulation/Backtesting.",
      "required": [
        "id",
        "label",
        "settings"
      ],
      "properties": {
        "id": {
          "type": "string",
          "description": "Eindeutige Szenario-Kennung (z. B. live, battery_10kwh)."
        },
        "label": {
          "type": "string",
          "description": "Anzeigename in der UI."
        },
        "settings": {
          "type": "object",
          "description": "Parameter-Override (flache Felder oder Referenzen auf Entitäten). Standort/Zeitzone kommen aus dem Hausprofil (house_profile_id), nicht aus settings.",
          "properties": {
            "battery_id": {
              "type": "string",
              "description": "Referenz auf batteries[].id in config.json."
            },
            "pv_system_ids": {
              "type": "array",
              "description": "Referenzen auf pv_systems[].id in components.json (Mehrfach-Auswahl).",
              "items": {
                "type": "string"
              }
            },
            "pv_system_id": {
              "type": "string",
              "description": "Veraltet — Einzelreferenz; wird beim Laden zu pv_system_ids normalisiert."
            },
            "import_tariff_id": {
              "type": "string",
              "description": "Referenz auf import_tariffs[].id in tariffs.json."
            },
            "export_tariff_id": {
              "type": "string",
              "description": "Referenz auf export_tariffs[].id in tariffs.json."
            },
            "house_profile_id": {
              "type": "string",
              "description": "Referenz auf profiles[].id in house_profiles.json."
            },
            "use_imported_pv": {
              "type": "boolean",
              "description": "Wenn true: Szenario-Explorer nutzt Hausprofil-pv_profile_csv statt PV aus Wetterdaten (Open-Meteo)."
            },
            "k_push_cent": {
              "type": "number"
            },
            "feed_in_mode": {
              "type": "string",
              "enum": [
                "fixed",
                "dynamic_epex"
              ]
            },
            "pv_tilt": {
              "type": "number"
            },
            "pv_azimuth": {
              "type": "number"
            },
            "pv_kwp": {
              "type": "number"
            },
            "battery_max_power_kw": {
              "type": "number"
            },
            "battery_efficiency": {
              "type": "number"
            },
            "battery_capacity_kwh": {
              "type": "number"
            },
            "battery_min_soc": {
              "type": "number"
            },
            "battery_max_soc": {
              "type": "number"
            },
            "threshold_power": {
              "type": "number"
            }
          }
        }
      }
    }
  }
}
